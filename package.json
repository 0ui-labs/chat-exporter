{
  "name": "chat-exporter",
  "private": true,
  "packageManager": "pnpm@10.9.2",
  "scripts": {
    "dev": "pnpm --filter @chat-exporter/shared build && pnpm --parallel --filter @chat-exporter/shared --filter @chat-exporter/server --filter @chat-exporter/web dev",
    "dev:web": "pnpm --filter @chat-exporter/web dev",
    "dev:server": "pnpm --filter @chat-exporter/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  }
}
