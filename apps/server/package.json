{
  "name": "@chat-exporter/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@chat-exporter/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@orpc/server": "^1.13.6",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.13",
    "jsdom": "^28.1.0",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.10.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
